  "codex_instructions": {
    "role": "You are a coding assistant, not a policy analyst.",
    "tasks": [
      "For each target_law, open the hourei_ndl_url and collect all amendment records shown in the law history.",
      "For each amendment, open its amendment law page and collect deliberation history entries.",
      "For each deliberation entry whose label is 趣旨説明, 提案理由説明, 修正部分趣旨説明, 質疑, 討論, 委員長報告, or 附帯決議, save the kokkai.ndl.go.jp URL as a source_event.",
      "For 趣旨説明 and 修正部分趣旨説明, extract change claims only when supported by raw_excerpt.",
      "For 質疑, extract discussion_points. Do not treat every question as a legal change.",
      "Preserve source URLs and raw excerpts. Do not invent missing values.",
      "Use null for unavailable values and verification_status='unverified' when not checked."
    ],
    "output_files": [
      "data/allowance_law_manifest.json",
      "data/amendments.json",
      "data/source_events.json",
      "data/extracted_change_claims.json",
      "data/discussion_points.json"
    ]
